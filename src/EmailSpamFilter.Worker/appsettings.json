{
  "ConfiguracoesImap": {
    "Servidor": "outlook.office365.com",
    "Porta": 993,
    "UsarSsl": true,
    "Email": "",
    "ClientId": ""
  },
  "ConfiguracoesFiltro": {
    "IntervaloSegundos": 30,
    "ArquivoBloqueio": "bloqueio.json",
    "Acao": "Deletar",
    "MaximoEmailsPorCiclo": 100,
    "MonitorarLixoEletronico": true,
    "ModoSimulacao": false
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/emailspamfilter-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
